{
	"mcpServers": {
		"mochi": {
			"type": "http",
			"url": "https://mochi.fast/mcp"
		},
		"bun-docs": {
			"type": "http",
			"url": "https://bun.com/docs/mcp"
		},
		"svelte": {
			"type": "http",
			"url": "https://mcp.svelte.dev/mcp"
		},
		"chrome-devtools": {
			"type": "stdio",
			"command": "bunx",
			"args": [
				"chrome-devtools-mcp@latest",
				"--headless=true",
				"--chrome-arg=--no-sandbox",
				"--chrome-arg=--disable-setuid-sandbox"
			],
			"env": {}
		}
	}
}
