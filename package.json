{
	"name": "codebay",
	"version": "0.2.0",
	"description": "Web UI for spinning up isolated devcontainer instances from any local folder, each with a browser-based VS Code (code-server) — built for parallel Claude Code workflows.",
	"type": "module",
	"license": "MIT",
	"author": "Stanislav Khromov",
	"homepage": "https://github.com/khromov/servbay#readme",
	"bugs": {
		"url": "https://github.com/khromov/codebay/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/khromov/codebay.git"
	},
	"keywords": [
		"devcontainer",
		"devcontainers",
		"code-server",
		"claude-code",
		"vscode",
		"docker",
		"bun"
	],
	"bin": {
		"codebay": "bin/codebay.ts"
	},
	"files": [
		"bin",
		"src",
		"public",
		"migrations",
		".mochi",
		"svelte.config.js",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"scripts": {
		"build": "mochi-framework build",
		"start": "bun src/index.ts",
		"prod": "bun run build && PORT=6969 bun run start",
		"dev": "MODE=development DISABLE_OPEN_BROWSER=1 DATA_DIR=./.codebay bun src/index.ts",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json --compiler-warnings 'attribute_illegal_colon:ignore' && tsc -p tsconfig.json --noEmit",
		"test": "bun test",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"checks": "bun run format && bun run typecheck && bun run test",
		"clean": "rimraf .mochi",
		"gen:chimes": "bun scripts/gen-chimes.ts",
		"debug:tokens": "bun scripts/debug-tokens.ts"
	},
	"dependencies": {
		"@devcontainers/cli": "^0.87.0",
		"@fontsource-variable/doto": "^5.2.10",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@lucide/svelte": "^1.21.0",
		"@zihaolam/bun-sqlite-migrations": "^1.0.3",
		"dockerode": "^5.0.1",
		"mochi-framework": "^0.8.2",
		"svelte": "^5.56.4",
		"svelte-french-toast": "^1.2.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bun": "1.3.14",
		"@types/dockerode": "^4.0.1",
		"eslint": "^10.6.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte-check": "4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1"
	},
	"overrides": {
		"msgpackr-extract": "npm:@mochi-framework/msgpackr-extract-stub@*",
		"svelte": "5.56.4"
	},
	"patchedDependencies": {
		"svelte-check@4.6.0": "patches/svelte-check@4.6.0.patch"
	}
}
